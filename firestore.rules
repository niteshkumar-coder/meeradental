rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{appointmentId} {
      allow create: if request.resource.data.name is string && request.resource.data.phone is string;
      allow read, write: if request.auth != null && request.auth.token.email == "niteshkumar9128ku@gmail.com";
    }
  }
}

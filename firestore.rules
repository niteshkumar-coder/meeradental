rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{appointmentId} {
      // Allow anyone to book an appointment and allow the admin (via frontend password) to manage them.
      // We are allowing public access here because the user requested a password-only login 
      // that doesn't rely on Google Auth, and anonymous auth might not be enabled.
      allow read, write: if true;
    }
  }
}
